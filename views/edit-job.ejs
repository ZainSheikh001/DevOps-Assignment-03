<%- include('partials/header') %>

<section class="form-section">
  <h1>Edit Job</h1>
  <% if (error) { %>
  <p class="error"><%= error %></p>
  <% } %>

  <form method="POST" action="/jobs/<%= job._id %>?_method=PUT" class="form-grid">
    <label>Title</label>
    <input name="title" value="<%= job.title %>" required />

    <label>Description</label>
    <textarea name="description" rows="5" required><%= job.description %></textarea>

    <label>Company</label>
    <input name="company" value="<%= job.company %>" required />

    <label>Location</label>
    <input name="location" value="<%= job.location %>" required />

    <button class="btn-primary" type="submit">Save Changes</button>
  </form>
</section>

<%- include('partials/footer') %>
