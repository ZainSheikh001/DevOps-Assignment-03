<%- include('partials/header') %>

<section class="hero">
  <h1>Find Your Next Opportunity</h1>
  <p>Discover curated job opportunities from top companies.</p>
</section>

<section>
  <h2>Latest Job Listings</h2>
  <% if (!jobs.length) { %>
  <p>No job postings yet.</p>
  <% } %>

  <div class="grid">
    <% jobs.forEach((job) => { %>
    <article class="card">
      <h3><%= job.title %></h3>
      <p class="muted"><%= job.company %> - <%= job.location %></p>
      <p><%= job.description.substring(0, 120) %>...</p>
      <a class="btn-secondary" href="/jobs/<%= job._id %>">View Details</a>
    </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
